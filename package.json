{
  "name": "ezfhir",
  "version": "0.1.0",
  "description": "AI-first MCP server for token-efficient FHIR specification access",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ezfhir": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ test/",
    "benchmark": "vitest run --config vitest.benchmark.config.ts",
    "eval": "npx tsx test/eval/run-eval.ts",
    "test:eval": "vitest run --config vitest.eval.config.ts",
    "generate": "echo 'Generate pipeline not yet implemented'"
  },
  "keywords": [
    "fhir",
    "mcp",
    "ai",
    "healthcare",
    "interoperability",
    "hl7"
  ],
  "author": "mfaughn",
  "repository": {
    "type": "git",
    "url": "https://github.com/mfaughn/ezfhir.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/turndown": "^5.0.6",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/lunr": "^2.3.7",
    "fhir-package-loader": "^2.2.3",
    "lunr": "^2.3.9",
    "turndown": "^7.2.2",
    "zod": "^4.3.6"
  }
}
